{
  "name": "ovo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Open-source proactive AI desktop assistant. Watches your screen, suggests next steps, runs 100% on your machine.",
  "keywords": [
    "ai-assistant",
    "proactive-ai",
    "desktop-app",
    "electron",
    "claude",
    "claude-code",
    "screen-ocr",
    "knowledge-graph",
    "productivity",
    "personal-ai",
    "local-first",
    "privacy-first",
    "macos",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/dushaobindoudou/ovo#readme",
  "bugs": {
    "url": "https://github.com/dushaobindoudou/ovo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dushaobindoudou/ovo.git"
  },
  "license": "MIT",
  "author": {
    "name": "dushaobin",
    "url": "https://github.com/dushaobindoudou"
  },
  "main": "dist-electron/electron/main.js",
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3",
      "@cherrystudio/mac-system-ocr"
    ]
  },
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && pnpm build:electron && cross-env NODE_ENV=development electron dist-electron/electron/main.js",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test:agents": "tsx scripts/smoke-agents.ts",
    "test:e2e:scenarios": "tsx scripts/e2e-log-scenarios.ts",
    "test:flow": "pnpm build:electron && cross-env ELECTRON_RUN_AS_NODE=1 electron dist-electron/scripts/simulate-ui-flow.js",
    "verify:p0": "tsx scripts/verify-p0.ts",
    "verify:real30": "pnpm build:electron && cross-env NODE_ENV=production OVO_RUN_REAL30=1 OVO_REAL_LOG_SCENARIOS=30 electron dist-electron/electron/main.js",
    "pack:dir": "pnpm build && electron-builder --dir",
    "pack:fresh": "pkill -f 'ovo.app/Contents/MacOS/ovo' 2>/dev/null; rm -rf out && pnpm pack:dir && open out/mac-arm64/ovo.app",
    "pack:mac": "pnpm build && electron-builder --mac dmg",
    "pack:all": "pnpm build && electron-builder -mwl",
    "smoke:postpack": "pnpm build:electron && cross-env ELECTRON_RUN_AS_NODE=1 electron dist-electron/scripts/postpack-smoke.js",
    "gen:icons": "pnpm build:electron && electron dist-electron/scripts/generate-icons.js",
    "test:ci": "pnpm typecheck && pnpm lint && pnpm build && pnpm test:agents && pnpm test:flow && pnpm test:e2e:scenarios",
    "start": "electron dist-electron/electron/main.js"
  },
  "dependencies": {
    "@cherrystudio/mac-system-ocr": "^0.2.7",
    "@types/three": "^0.184.0",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "execa": "^9.5.2",
    "lucide-react": "^1.16.0",
    "msedge-tts": "^2.0.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^6.0.1",
    "three": "^0.184.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/better-sqlite3": "^7.6.12",
    "@types/electron": "^1.6.12",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^34.5.8",
    "electron-builder": "^26.0.12",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
