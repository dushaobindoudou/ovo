{
  "name": "ovo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ovo - 主动式 AI 桌面助手",
  "main": "dist-electron/main.js",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && pnpm build:electron && cross-env NODE_ENV=development electron dist-electron/main.js",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "start": "electron dist-electron/main.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "execa": "^9.5.2",
    "lucide-react": "^0.518.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^6.0.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/better-sqlite3": "^7.6.12",
    "@types/electron": "^1.6.12",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^34.5.8",
    "electron-builder": "^26.0.12",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
