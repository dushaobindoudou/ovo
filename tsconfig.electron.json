{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["electron/**/*.ts", "scripts/simulate-ui-flow.ts", "scripts/postpack-smoke.ts", "scripts/generate-icons.ts"]
}
